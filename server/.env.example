PORT=3001
JWT_SECRET=change-this-in-production

# --- Email (free options) ---
# Option A: Brevo (free 300 emails/day) — https://www.brevo.com
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your-brevo-login-email
# SMTP_PASS=your-brevo-smtp-key
# SMTP_FROM="Milkbasket <noreply@yourdomain.com>"

# Option B: Gmail app password
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-app-password

# If SMTP is not set, Ethereal test email is used (check server console for preview URL)

# --- SMS (free options for India) ---
# Fast2SMS — free dev credits at https://www.fast2sms.com
FAST2SMS_API_KEY=your-fast2sms-api-key

# TextBelt — 1 free SMS/day (mostly US numbers)
# ENABLE_TEXTBELT_SMS=true
# TEXTBELT_API_KEY=textbelt

# --- Razorpay Payment Gateway ---
# Sign up at https://razorpay.com and use Test Mode keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret-key
