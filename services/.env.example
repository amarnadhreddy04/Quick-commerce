JWT_SECRET=milkbasket-dev-secret-change-in-production

GATEWAY_PORT=3001
AUTH_PORT=3011
CATALOG_PORT=3012
ORDER_PORT=3013
PAYMENT_PORT=3014
USER_PORT=3015
SETTINGS_PORT=3016
NOTIFICATION_PORT=3017
SYNC_PORT=3018

# Razorpay mode: "live" (real payments), "auto" (demo without keys), or omit for demo
# Live keys start with rzp_live_ ; test keys start with rzp_test_
RAZORPAY_MODE=auto
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Optional webhook secret (Dashboard → Webhooks → payment.captured)
# Webhook URL: https://your-domain.com/api/payments/webhook
RAZORPAY_WEBHOOK_SECRET=

# Optional: Email (SMTP or Ethereal auto in dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Pachari" <noreply@pachari.com>

# Optional: SMS
FAST2SMS_API_KEY=
ENABLE_TEXTBELT_SMS=false
